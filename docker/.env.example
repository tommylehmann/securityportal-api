# Copy this file to `.env` and adjust the values for your deployment.
# Never commit a real `.env` file; it is git-ignored.

# --- CSAF Trusted Provider ingestion ---
# Base URL (domain) of the CSAF Trusted Provider to pull advisories from.
SECURITYPORTAL_PROVIDER_URL=https://provider.example.com
# Comma-separated list of TLP labels that may be published publicly.
SECURITYPORTAL_PUBLISHABLE_TLP=WHITE,UNLABELED
# Interval between ingestion polls (Go duration syntax, e.g. 15m, 1h).
SECURITYPORTAL_POLL_INTERVAL=15m

# --- Read-only HTTP API ---
# Comma-separated browser origins allowed to call the API cross-origin.
# Leave empty in the Compose deployment — the browser never contacts the API
# directly (same-origin via Caddy, ADR-0011).  Only set for non-proxy deploys.
SECURITYPORTAL_CORS_ORIGINS=
# Per-query statement timeout on the read pool (Go duration syntax, e.g. 5s,
# 10s). A slow or expensive query is cancelled by Postgres when this deadline
# is exceeded, protecting against DoS via long-running SQL (C-7 / R-4).
# Set to 0 to disable (not recommended for production).
SECURITYPORTAL_QUERY_TIMEOUT=5s

# --- PostgreSQL ---
# Credentials used to initialize the postgres container. Use strong values
# in real deployments; these placeholders are for local development only.
POSTGRES_USER=securityportal
POSTGRES_PASSWORD=changeme
POSTGRES_DB=securityportal
# DSN the API uses to reach the database. The host `db` is the compose service.
SECURITYPORTAL_DATABASE_DSN=postgres://securityportal:changeme@db:5432/securityportal?sslmode=disable

# --- SSR / API base split (ADR-0011 / task 33) ---
# Internal URL the web service's SSR load functions use to reach the API
# directly over the Docker network (bypasses Caddy, avoids a loopback hop).
# In Compose this is always http://api:8081.  For non-Compose deployments set
# this to the internal/loopback address of the API server.
SECURITYPORTAL_API_INTERNAL_URL=http://api:8081

# --- Caddy reverse proxy (ADR-0011) ---
# Site address for the Caddy site block.  Unset or "localhost" selects the
# local self-signed certificate (MODE 1, default).  Set to a public FQDN for
# ACME / Let's Encrypt (MODE 2) or BYO (MODE 3) — see docker/caddy/Caddyfile.
SP_SITE_ADDRESS=localhost

# ACME / Let's Encrypt email (MODE 2).
# Uncomment and set to enable ACME; leave commented out (not empty) for MODE 1.
# Setting this to an empty string would break the Caddy self-signed fallback —
# comment the line out entirely rather than leaving it blank.
# SP_ACME_EMAIL=ops@example.com

# BYO certificate paths (MODE 3).
# Absolute paths *inside the caddy container* to the PEM files.
# These are documentation-only in the default Compose setup.  To use BYO:
#   1. Set SP_SITE_ADDRESS to your FQDN.
#   2. Do not set SP_ACME_EMAIL.
#   3. Add bind-mounts for the cert and key files to the caddy service.
#   4. Mount docker/caddy/Caddyfile.byo as /etc/caddy/Caddyfile.
# See docker/caddy/Caddyfile.byo for the full instructions.
# SP_TLS_CERT=/absolute/path/to/fullchain.pem
# SP_TLS_KEY=/absolute/path/to/privkey.pem

# Rate limiting (requires caddy-ratelimit module — see docker/caddy/Caddyfile).
# Requests per sliding window per source IP before Caddy returns 429.
# These values are forwarded into the caddy container via the compose
# environment: block (SA-26 / C-14 / ADR-0011); changing them here takes
# effect on the next `docker compose up`.
SP_RATE_LIMIT_REQUESTS=60
SP_RATE_LIMIT_WINDOW=1m
