# Copy this file to `.env` and adjust the values for your deployment.
# Never commit a real `.env` file; it is git-ignored.

# --- CSAF Trusted Provider ingestion ---
# Base URL (domain) of the CSAF Trusted Provider to pull advisories from.
SECURITYPORTAL_PROVIDER_URL=https://provider.example.com
# Comma-separated list of TLP labels that may be published publicly.
SECURITYPORTAL_PUBLISHABLE_TLP=WHITE,UNLABELED
# Interval between ingestion polls (Go duration syntax, e.g. 15m, 1h).
SECURITYPORTAL_POLL_INTERVAL=15m

# --- Read-only HTTP API ---
# Comma-separated browser origins allowed to call the API cross-origin. Leave
# empty to emit no CORS headers; set to the web app's public origin in
# production, e.g. https://portal.example.com.
SECURITYPORTAL_CORS_ORIGINS=
# Per-query statement timeout on the read pool (Go duration syntax, e.g. 5s,
# 10s). A slow or expensive query is cancelled by Postgres when this deadline
# is exceeded, protecting against DoS via long-running SQL (C-7 / R-4).
# Set to 0 to disable (not recommended for production).
SECURITYPORTAL_QUERY_TIMEOUT=5s

# --- PostgreSQL ---
# Credentials used to initialize the postgres container. Use strong values
# in real deployments; these placeholders are for local development only.
POSTGRES_USER=securityportal
POSTGRES_PASSWORD=changeme
POSTGRES_DB=securityportal
# DSN the API uses to reach the database. The host `db` is the compose service.
SECURITYPORTAL_DATABASE_DSN=postgres://securityportal:changeme@db:5432/securityportal?sslmode=disable

# --- Published ports on the host ---
API_PORT=8081
WEB_PORT=8080
