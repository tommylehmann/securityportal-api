# Compiled binaries
/cmd/securityportal-api/securityportal-api
*.exe
*.test
*.out

# Release artifacts (produced by `make dist` / the release workflow)
/dist/
*-sbom.cdx.json
*-sbom.spdx.json

# Go workspace / vendor
/vendor/
go.work
go.work.sum

# Local environment overrides (never commit secrets)
.env
docker/.env

# Operator-provided runtime branding content (the *.md.example templates,
# README.md and .gitkeep stay tracked; real legal text and logos do not).
docker/branding/legal/*.md
docker/branding/logo.*

# Editor / OS noise
.DS_Store
*.swp

# codegraph local index (security review F4 — may contain copied secrets)
.codegraph/

# Serena MCP local project config (tool-generated, not project source)
.serena/

# Helm dependency archives — fetched via `helm dependency build` (Chart.lock
# pins the version); not vendored into the repo.
/deploy/helm/securityportal/charts/
